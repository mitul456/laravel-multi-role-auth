{
    "name": "mitul456/laravel-multi-role-auth",
    "description": "A comprehensive multi-role authentication system for Laravel",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Mitul456\\LaravelMultiRoleAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mitul456\\LaravelMultiRoleAuth\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Md Parvez Mosharrof Mitul",
            "email": "mitulmdparvez@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mitul456\\LaravelMultiRoleAuth\\LaravelMultiRoleAuthServiceProvider"
            ]
        }
    }
}